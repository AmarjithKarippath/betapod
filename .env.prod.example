# --- DB ---
POSTGRES_USER=apptest
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=apptest

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API ---
API_SECRET_KEY=replace-with-openssl-rand-hex-32
API_JWT_EXPIRE_DAYS=7

# Public landing on root, SPA on app.<domain>. Cookies share .<domain> so login on app.* works.
API_CORS_ORIGINS=https://betapod.io,https://app.betapod.io
API_COOKIE_DOMAIN=.betapod.io

# --- Loopback ports that CloudPanel proxies to ---
# Pick any free ports on the VM; defaults shown.
API_PORT=8001
WEB_PORT=8002
LANDING_PORT=8003

# --- Frontends ---
NEXT_PUBLIC_APP_URL=https://app.betapod.io
NEXT_PUBLIC_SITE_URL=https://betapod.io
